# Officia environment variables
# Copy this file to .env.local for local development or configure the same keys in your hosting provider.
# Never commit real secrets.

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
APP_URL=http://localhost:3000

# Database
# Local dev (docker-compose.yml — postgres:15 on localhost:5432):
DATABASE_URL=postgres://postgres:postgrespassword@localhost:5432/officia
# Hosted Postgres (Neon, Supabase, Railway, etc.):
# DATABASE_URL=postgres://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require

# Clerk authentication
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_YOUR_CLERK_PUBLISHABLE_KEY
CLERK_SECRET_KEY=sk_test_YOUR_CLERK_SECRET_KEY
CLERK_WEBHOOK_SECRET=whsec_YOUR_CLERK_WEBHOOK_SECRET
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/bg/dashboard
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/bg/dashboard

# Stripe payments
STRIPE_SECRET_KEY=sk_test_YOUR_STRIPE_SECRET_KEY
STRIPE_WEBHOOK_SECRET=whsec_YOUR_STRIPE_WEBHOOK_SECRET

# Stripe subscription price IDs - required when plan checkout is implemented
STRIPE_PRICE_STARTER_MONTHLY=price_YOUR_STARTER_MONTHLY_PRICE_ID
STRIPE_PRICE_STARTER_ANNUAL=price_YOUR_STARTER_ANNUAL_PRICE_ID
STRIPE_PRICE_PRO_MONTHLY=price_YOUR_PRO_MONTHLY_PRICE_ID
STRIPE_PRICE_PRO_ANNUAL=price_YOUR_PRO_ANNUAL_PRICE_ID
STRIPE_PRICE_ENTERPRISE_MONTHLY=price_YOUR_ENTERPRISE_MONTHLY_PRICE_ID
STRIPE_PRICE_ENTERPRISE_ANNUAL=price_YOUR_ENTERPRISE_ANNUAL_PRICE_ID

# AI providers
ANTHROPIC_API_KEY=sk-ant-api03-YOUR_ANTHROPIC_API_KEY
ANTHROPIC_MODEL=claude-sonnet-4-6
OPENAI_API_KEY=sk-YOUR_OPENAI_API_KEY
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
DEEPGRAM_API_KEY=YOUR_DEEPGRAM_API_KEY

# E2E (Playwright + Clerk)
# Test user must exist in Clerk and be linked to a tenant row in the DB (users.clerk_id).
E2E_CLERK_USER_EMAIL=e2e@your-company.test
E2E_LOCALE=bg
PLAYWRIGHT_BASE_URL=http://localhost:3000

UPSTASH_REDIS_URL=https://YOUR_UPSTASH_REDIS_URL
UPSTASH_REDIS_TOKEN=YOUR_UPSTASH_REDIS_TOKEN

# Scheduled jobs / webhooks - optional
CRON_SECRET=your_cron_secret
AI_WEBHOOK_SECRET=your_ai_webhook_secret

# Bulgarian compliance / signing integrations - optional until enabled
EVROTRUST_API_KEY=YOUR_EVROTRUST_API_KEY
TSA_API_KEY=YOUR_TIMESTAMP_AUTHORITY_API_KEY

# NAP VAT direct submit (ZIP upload with mTLS)
# Use NAP_MOCK_MODE=true for local/dev without certificates
NAP_MOCK_MODE=true
NAP_ENABLED=false
NAP_VAT_SUBMIT_URL=https://portal.nra.bg/vat/upload
NAP_TEST_CERT_PATH=/path/to/nap-test.pem
NAP_TEST_KEY_PATH=/path/to/nap-test.key
NAP_REJECT_UNAUTHORIZED=true

# PSD2 bank sync (GoCardless Nordigen / Bank Account Data API v2)
NORDIGEN_SECRET_ID=YOUR_NORDIGEN_SECRET_ID
NORDIGEN_SECRET_KEY=YOUR_NORDIGEN_SECRET_KEY
NORDIGEN_USE_SANDBOX=true
